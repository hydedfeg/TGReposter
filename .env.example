# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: The URL of your Supabase project (e.g. https://xyz.supabase.co).
# To connect to Supabase, create a table named "curator_settings" (see schema instructions).
SUPABASE_URL="

# SUPABASE_ANON_KEY: The public/anon API key of your Supabase project.
SUPABASE_ANON_KEY=

# DATABASE_URL: Optional. The direct PostgreSQL connection URI of your Supabase database.
# If provided, the application can auto-generate and bootstrap tables for you.
# Format: postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres
DATABASE_URL=

# OPENROUTER_API_KEY: Optional. The API key for OpenRouter AI to enable alternative LLM models.
# Users configure this via the Secrets panel in the AI Studio UI.
OPENROUTER_API_KEY=
